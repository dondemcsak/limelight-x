<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:components="using:LimelightX.UI.Components"
        xmlns:workspace="using:LimelightX.UI.ViewModels.Workspace"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="700"
        x:Class="LimelightX.UI.Views.MainWindow"
        x:DataType="workspace:WorkspaceViewModel"
        Title="Limelight-X"
        Icon="/assets/limelightx.ico"
        Width="1200" Height="800"
        Background="{StaticResource BackgroundPrimaryBrush}">

  <!--
    Folder-explorer + tab-strip workspace shell (ui-architecture.md §4,
    ui-routing-navigation.md §2): title bar with the Settings gear, a
    resizable Explorer pane, and a tab strip + content area. Settings is an
    overlay (IsSettingsOpen), not a separate page - the previously active tab
    remains underneath, unaffected, while it is shown.
  -->
  <Window.KeyBindings>
    <KeyBinding Gesture="Ctrl+R" Command="{Binding ActiveCnlEditor.RunCommand}" />
    <KeyBinding Gesture="Ctrl+E" Command="{Binding ActiveCnlEditor.ExplainCommand}" />
    <KeyBinding Gesture="Ctrl+N" Command="{Binding NewLlxFileCommand}" />
    <KeyBinding Gesture="Ctrl+O" Command="{Binding OpenFileCommand}" />
    <KeyBinding Gesture="Ctrl+Shift+S" Command="{Binding SaveAsCommand}" />
    <KeyBinding Gesture="Ctrl+OemComma" Command="{Binding OpenSettingsCommand}" />
    <KeyBinding Gesture="Ctrl+W" Command="{Binding CloseActiveTabCommand}" />
    <KeyBinding Gesture="Ctrl+Tab" Command="{Binding NextTabCommand}" />
    <KeyBinding Gesture="Ctrl+Shift+Tab" Command="{Binding PreviousTabCommand}" />
    <!-- Ctrl+K, Ctrl+O (Open Folder), Ctrl+K, S (Save All), and plain Ctrl+S
         (Save, or Settings' own Save while that modal is open) are all
         handled in code-behind (see the tunnel-routed KeyDown handler in
         MainWindow.axaml.cs) - Ctrl+K is a two-key chord Avalonia's
         KeyBinding has no primitive for, and plain Ctrl+S must resolve
         between two different commands depending on IsSettingsOpen. -->
  </Window.KeyBindings>

  <Panel>
    <Grid RowDefinitions="Auto,*">

      <Border Grid.Row="0"
              Background="{StaticResource BackgroundSecondaryBrush}"
              BorderBrush="{StaticResource BorderBrush}"
              BorderThickness="0,0,0,1"
              Padding="{StaticResource PaddingMediumThickness}">
        <Grid ColumnDefinitions="Auto,Auto,*,Auto">
          <TextBlock Grid.Column="0" Text="Limelight-X"
                     Foreground="{StaticResource TextPrimaryBrush}"
                     FontFamily="{StaticResource InterFontFamily}"
                     FontSize="{StaticResource FontSizeMedium}"
                     VerticalAlignment="Center"
                     Margin="0,0,16,0" />
          <components:MenuBar Grid.Column="1" VerticalAlignment="Center" />
          <components:SettingsGearButton Grid.Column="3" />
        </Grid>
      </Border>

      <Grid Grid.Row="1">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="220" MinWidth="150" MaxWidth="480" />
          <ColumnDefinition Width="4" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <components:FileTreeView Grid.Column="0" />

        <GridSplitter Grid.Column="1" Width="4"
                      Background="{StaticResource BorderBrush}"
                      ResizeDirection="Columns"
                      HorizontalAlignment="Stretch" />

        <DockPanel Grid.Column="2">
          <components:TabStrip DockPanel.Dock="Top" />
          <components:TabContentHost />
        </DockPanel>
      </Grid>

    </Grid>

    <Border Background="#CC000000" IsVisible="{Binding IsSettingsOpen}">
      <components:SettingsModalView x:Name="SettingsModal" />
    </Border>

    <Border Background="#CC000000" IsVisible="{Binding IsAboutOpen}">
      <components:AboutModalView x:Name="AboutModal" />
    </Border>
  </Panel>

</Window>
