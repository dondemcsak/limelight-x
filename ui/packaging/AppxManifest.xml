<?xml version="1.0" encoding="utf-8"?>
<!--
  MSIX manifest for Limelight-X (ui-build-pipeline.md §8, ui-deployment.md §2-3).
  No app icon/branding is specified anywhere in spec/ux/*, so the referenced
  assets under packaging/assets/ are minimal placeholders (dark background +
  accent-colored mark from styles/Colors.axaml), not a designed brand icon -
  flagged here the same way other spec gaps were flagged in the implementation
  plan, not silently invented.

  Publisher/PublisherDisplayName use a placeholder identity since no code-signing
  certificate is specified (the spec requires the installer to remain unsigned -
  ui-build-pipeline.md §8.1, §3.5). A self-signed cert subject must match
  Publisher exactly if this package is ever signed for local sideload testing.
-->
<Package
  xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
  xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
  xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
  IgnorableNamespaces="uap rescap">

  <Identity
    Name="LimelightX"
    Publisher="CN=LimelightX-Dev"
    Version="0.5.1.0" />

  <Properties>
    <DisplayName>Limelight-X</DisplayName>
    <PublisherDisplayName>Limelight-X</PublisherDisplayName>
    <Logo>assets\Square150x150Logo.png</Logo>
  </Properties>

  <Dependencies>
    <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.22621.0" />
  </Dependencies>

  <Resources>
    <Resource Language="en-us" />
  </Resources>

  <Applications>
    <Application Id="LimelightXApp" Executable="LimelightX.exe" EntryPoint="Windows.FullTrustApplication">
      <uap:VisualElements
        DisplayName="Limelight-X"
        Description="Limelight-X - CNL pipeline editor and executor"
        BackgroundColor="#0D0D0D"
        Square150x150Logo="assets\Square150x150Logo.png"
        Square44x44Logo="assets\Square44x44Logo.png">
        <uap:DefaultTile
          Wide310x150Logo="assets\Wide310x150Logo.png"
          Square71x71Logo="assets\Square71x71Logo.png"
          Square310x310Logo="assets\Square310x310Logo.png" />
        <uap:SplashScreen Image="assets\SplashScreen.png" />
      </uap:VisualElements>
    </Application>
  </Applications>

  <Capabilities>
    <rescap:Capability Name="runFullTrust" />
  </Capabilities>

</Package>
