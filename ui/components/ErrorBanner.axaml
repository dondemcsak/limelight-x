<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:errors="using:LimelightX.UI.ViewModels.Errors"
             mc:Ignorable="d" d:DesignWidth="800"
             x:Class="LimelightX.UI.Components.ErrorBanner"
             x:DataType="errors:ErrorBannerViewModel">

  <!--
    Tab-scoped error banner (ui-components.md §7.1, ui-error-handling.md §9).
    Bound directly to an ErrorBannerViewModel instance (one per tab's
    PipelineExecutionViewModel, one on SettingsViewModel) - never a single
    app-wide instance, so switching tabs never shows or hides another tab's
    banner.
  -->
  <Border IsVisible="{Binding IsVisible}"
          Background="{StaticResource StatusErrorBrush}"
          CornerRadius="{StaticResource BorderRadius}"
          Padding="{StaticResource PaddingMediumThickness}">
    <StackPanel Spacing="{StaticResource PanelSpacing}">
      <ItemsControl ItemsSource="{Binding Errors}">
        <ItemsControl.ItemTemplate>
          <DataTemplate DataType="errors:UiError">
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,4">
              <TextBlock Text="{Binding Code}" Foreground="White" FontFamily="{StaticResource JetBrainsMonoFontFamily}" FontSize="{StaticResource FontSizeSmall}" />
              <TextBlock Text="{Binding Message}" Foreground="White" FontFamily="{StaticResource InterFontFamily}" FontSize="{StaticResource FontSizeSmall}" TextWrapping="Wrap" />
            </StackPanel>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <Button Classes="icon" HorizontalAlignment="Right"
              Command="{Binding DismissCommand}"
              Content="Dismiss"
              AutomationProperties.Name="Dismiss errors" />
    </StackPanel>
  </Border>

</UserControl>
