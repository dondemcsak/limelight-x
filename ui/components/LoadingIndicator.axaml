<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="300"
             x:Class="LimelightX.UI.Components.LoadingIndicator"
             x:Name="Root">

  <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding IsLoading, ElementName=Root}">
    <ProgressBar IsIndeterminate="True" Width="16" Height="16" />
    <TextBlock Text="{Binding Text, ElementName=Root}"
               Foreground="{StaticResource TextSecondaryBrush}"
               FontFamily="{StaticResource InterFontFamily}"
               FontSize="{StaticResource FontSizeSmall}" />
  </StackPanel>

</UserControl>
