<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!--
    Form input styling (ui-styling-theming.md §4.7) - reuses existing tokens
    only, no new colors/shadows/timings introduced. Used by TextField,
    SecureTextField, SelectField components.
  -->

  <Style Selector="TextBox.formField">
    <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource BorderRadius}" />
    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
    <Setter Property="FontFamily" Value="{StaticResource InterFontFamily}" />
    <Setter Property="FontSize" Value="{StaticResource FontSizeMedium}" />
    <Setter Property="Padding" Value="{StaticResource PaddingMediumThickness}" />
  </Style>
  <Style Selector="TextBox.formField:focus /template/ Border#PART_BorderElement">
    <Setter Property="BorderBrush" Value="{StaticResource AccentPrimaryBrush}" />
  </Style>
  <Style Selector="TextBox.formField.fieldError">
    <Setter Property="BorderBrush" Value="{StaticResource StatusErrorBrush}" />
  </Style>

  <Style Selector="TextBlock.fieldLabel">
    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
    <Setter Property="FontFamily" Value="{StaticResource InterFontFamily}" />
    <Setter Property="FontSize" Value="{StaticResource FontSizeSmall}" />
    <Setter Property="Margin" Value="0,0,0,4" />
  </Style>

  <Style Selector="TextBlock.fieldError">
    <Setter Property="Foreground" Value="{StaticResource StatusErrorBrush}" />
    <Setter Property="FontFamily" Value="{StaticResource InterFontFamily}" />
    <Setter Property="FontSize" Value="{StaticResource FontSizeSmall}" />
    <Setter Property="Margin" Value="0,4,0,0" />
  </Style>

  <Style Selector="ComboBox.formField">
    <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource BorderRadius}" />
    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
    <Setter Property="FontFamily" Value="{StaticResource InterFontFamily}" />
    <Setter Property="FontSize" Value="{StaticResource FontSizeMedium}" />
    <Setter Property="Padding" Value="{StaticResource PaddingMediumThickness}" />
  </Style>

</Styles>
