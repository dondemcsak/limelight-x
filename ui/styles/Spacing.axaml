<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!--
    Compact developer-tool layout density (ui-styling-theming.md §9). Raw
    Double values for numeric uses (e.g. StackPanel.Spacing); Thickness
    variants for Margin/Padding-typed properties, both derived from the same
    spec values so there is exactly one source of truth per token.
  -->
  <x:Double x:Key="PaddingSmall">4</x:Double>
  <x:Double x:Key="PaddingMedium">8</x:Double>
  <x:Double x:Key="PaddingLarge">12</x:Double>
  <x:Double x:Key="PanelSpacing">8</x:Double>

  <Thickness x:Key="PaddingSmallThickness">4</Thickness>
  <Thickness x:Key="PaddingMediumThickness">8</Thickness>
  <Thickness x:Key="PaddingLargeThickness">12</Thickness>
  <Thickness x:Key="ButtonPadding">8,4</Thickness>
  <Thickness x:Key="SectionSpacingThickness">0,12</Thickness>
  <Thickness x:Key="PanelBottomSpacingThickness">0,0,0,8</Thickness>

  <CornerRadius x:Key="BorderRadius">6</CornerRadius>

</ResourceDictionary>
